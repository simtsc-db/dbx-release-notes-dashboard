{
  "datasets": [
    {
      "name": "release_notes",
      "displayName": "Release Notes",
      "config": {
        "version": 1.1,
        "source": "main.databricks_release_notes.release_notes",
        "dimensions": [
          {
            "name": "cloud",
            "expr": "cloud",
            "displayName": "Cloud"
          },
          {
            "name": "title",
            "expr": "title",
            "displayName": "Title"
          },
          {
            "name": "description",
            "expr": "description",
            "displayName": "Description"
          },
          {
            "name": "pub_date",
            "expr": "pub_date",
            "displayName": "Published Date",
            "format": {
              "type": "date",
              "dateFormat": "year_month_day"
            }
          },
          {
            "name": "pub_month",
            "expr": "DATE_TRUNC('MONTH', pub_date)",
            "displayName": "Published Month",
            "format": {
              "type": "date",
              "dateFormat": "locale_short_month"
            }
          },
          {
            "name": "url",
            "expr": "url",
            "displayName": "URL"
          },
          {
            "name": "status",
            "expr": "status",
            "displayName": "Status"
          },
          {
            "name": "feature",
            "expr": "feature",
            "displayName": "Feature"
          },
          {
            "name": "impact",
            "expr": "impact",
            "displayName": "Impact"
          },
          {
            "name": "categories",
            "expr": "categories",
            "displayName": "Categories"
          },
          {
            "name": "source",
            "expr": "source",
            "displayName": "Source"
          }
        ],
        "measures": [
          {
            "name": "entry_count",
            "expr": "COUNT(*)",
            "displayName": "Entry Count"
          }
        ]
      }
    }
  ],
